# Clerk publishable key (frontend auth). Use pk_live_... in production.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxx

# Backend API base URL (include the /api suffix). In prod: https://<render-api-host>/api
VITE_API_BASE_URL=http://localhost:8000/api

# Sentry DSN for frontend error monitoring (optional; leave blank to disable).
VITE_SENTRY_DSN=
