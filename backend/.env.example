# ---- Core ----
# Set to "production" in prod — this disables the dev auth-bypass and local-storage fallback.
ENVIRONMENT=development
LOG_LEVEL=INFO
# Comma-separated list of allowed CORS origins (frontend URLs); set to the Vercel origin in prod.
CORS_ORIGINS=http://localhost:5173
# Max accepted upload size in megabytes (rejected above this).
MAX_UPLOAD_MB=25

# ---- Database (Supabase Postgres in prod, local pgvector in dev) ----
# Use the async driver form for SQLAlchemy; Alembic derives the sync form automatically.
DATABASE_URL=postgresql+asyncpg://notebooklm:notebooklm@localhost:5432/notebooklm

# ---- Redis (Celery broker + result backend) ----
REDIS_URL=redis://localhost:6379/0

# ---- Clerk (auth) ----
# Backend verifies Clerk-issued JWTs against this issuer's JWKS.
CLERK_JWKS_URL=https://<your-subdomain>.clerk.accounts.dev/.well-known/jwks.json
CLERK_ISSUER=https://<your-subdomain>.clerk.accounts.dev
# Accepted JWT audience. Optional — Clerk's default session tokens carry no `aud` claim, so leave
# blank unless you configure a Clerk JWT template with an audience.
CLERK_AUDIENCE=

# ---- Supabase Storage (object storage for uploaded files) ----
SUPABASE_URL=https://<your-project>.supabase.co
SUPABASE_SERVICE_KEY=<service-role-key>
SUPABASE_STORAGE_BUCKET=documents

# ---- LLM (OpenRouter — open models: Llama 3.3 / Qwen 2.5) ----
OPENROUTER_API_KEY=<key>
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=meta-llama/llama-3.3-70b-instruct

# ---- Embeddings + Rerank (NVIDIA Nemotron free models via OpenRouter) ----
# EMBEDDINGS_API_KEY / RERANK_API_KEY are OPTIONAL: if blank they default to OPENROUTER_API_KEY.
# The embed model outputs 2048-dim vectors but is Matryoshka-trained, so we truncate to 1024.
EMBEDDINGS_API_KEY=
EMBEDDINGS_BASE_URL=https://openrouter.ai/api/v1
EMBEDDING_MODEL=nvidia/llama-nemotron-embed-vl-1b-v2:free
EMBEDDING_DIM=1024
RERANK_API_KEY=
RERANK_BASE_URL=https://openrouter.ai/api/v1
RERANK_MODEL=nvidia/llama-nemotron-rerank-vl-1b-v2:free

# ---- Retrieval tuning ----
RETRIEVAL_TOP_K=40
RERANK_TOP_N=8
CHUNK_TARGET_TOKENS=512
CHUNK_OVERLAP_RATIO=0.2

# ---- Monitoring ----
SENTRY_DSN=
